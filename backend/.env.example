# Welke omgeving is dit? production | staging | development
# Staging-Railway zet APP_ENV=staging; productie zet APP_ENV=production.
# Zichtbaar in /health en /api/health zodat je nooit per ongeluk prod test.
APP_ENV=development
PORT=3000
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
DSO_ENV=LTO
DSO_ADAPTER_URL=
DSO_ADAPTER_CLIENT_ID=
DSO_ADAPTER_CERT_ALIAS=
AI_VALIDATOR_URL=
AI_VALIDATOR_TIMEOUT_MS=8000

# DSO Digikoppeling Adapter Configuratie
DIGIKOPPELING_API_URL=https://api.onze-adapter.nl/v1/stam/submit
DIGIKOPPELING_API_KEY=
DIGIKOPPELING_CERT_PATH=./certs/pkioverheid.pem
DKA_INTERNAL_URL=http://localhost:8080/api/stam/outbound
DKA_INTERNAL_API_KEY=
DKA_TIMEOUT_MS=10000
DKA_LTO_URL=http://localhost:8080/api/stam/lto-test
DKA_TEST_API_KEY=
LTO_LOG_FILE=./dso_lto_bewijs.log

# KiK / WKI koppeling
KIK_API_URL=
KIK_API_KEY=
KIK_API_BASE_URL=
KIK_API_TOKEN=
KIK_TIMEOUT_MS=10000
KIK_RETRY_ENABLED=true
KIK_RETRY_SCHEDULE=0 * * * *
APP_DEEP_LINK_SCHEME=wkb-snap-sync

# AFAS Profit
AFAS_ENVIRONMENT_ID=
AFAS_TOKEN=
AFAS_TIMEOUT_MS=10000
EXACT_DIVISION_ID=
EXACT_TIMEOUT_MS=10000

# BIM / BCF koppeling
BCF_SERVER_URL=
BCF_API_TOKEN=
BCF_TIMEOUT_MS=10000

# Review webhooks worden per project beheerd via Supabase tabel
# public.review_webhook_endpoints

# Adobe Document Generation API (PDF Services) — dossiermotor
# Aanmaken in de Adobe Developer Console (PDF Services API). Dit zijn GEEN
# echte secrets; vul je eigen waarden in een lokale .env die niet in git komt.
PDF_SERVICES_CLIENT_ID=
PDF_SERVICES_CLIENT_SECRET=
# Pad/naam van het getagde Word-sjabloon in de bucket `dossier-templates`.
DOSSIER_TEMPLATE_BUCKET=dossier-templates
DOSSIER_TEMPLATE_PATH=dossier-sjabloon.docx
# Bucket waar gegenereerde dossier-PDF's worden bewaard.
DOSSIER_BUCKET=dossiers
# Nachtelijke auto-refresh van dossiers (cron). Standaard uit tot het sjabloon
# en de Adobe-credentials staan.
DOSSIER_REFRESH_ENABLED=false
DOSSIER_REFRESH_SCHEDULE=0 3 * * *
